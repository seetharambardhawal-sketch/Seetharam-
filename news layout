            </article>

            <article>
                <h2>Holiday Notice</h2>
                <p>School will remain closed on Monday due to a public holiday.</p>
            </article>

        </section>

        <!-- Sidebar -->
        <aside>

            <h2>Upcoming Events</h2>

            <ul>
                <li>Drawing Competition</li>
                <li>Sports Meet</li>
                <li>Quiz Competition</li>
